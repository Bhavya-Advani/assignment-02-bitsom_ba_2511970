import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity

# 1. Initialize the model
model = SentenceTransformer('all-MiniLM-L6-v2')

# 2. 10 Sentences across 3 topics
sentences = [
    "The opening batsman hit a magnificent century in the test match.", # Cricket
    "Spinners often struggle to find grip on a damp outfield.", # Cricket
    "The umpire signaled a wide ball after the delivery veered off track.", # Cricket
    "Slow-cooking the brisket at a low temperature ensures maximum tenderness.", # Cooking
    "Always sauté the onions until they are translucent before adding garlic.", # Cooking
    "A pinch of saffron can drastically change the aroma of the biryani.", # Cooking
    "Whisking the egg whites to stiff peaks is essential for a light souffle.", # Cooking
    "Two-factor authentication is a critical defense against phishing attacks.", # Cybersecurity
    "The firewall blocked a suspicious IP address attempting an unauthorized login.", # Cybersecurity
    "Zero-day vulnerabilities pose a significant risk to enterprise software.", # Cybersecurity
]

# 3. Generate Embeddings
embeddings = model.encode(sentences)

# 4. Compute 10x10 Cosine Similarity Matrix
similarity_matrix = cosine_similarity(embeddings)

# 5. Display Heatmap
plt.figure(figsize=(10, 8))
sns.heatmap(similarity_matrix, annot=True, cmap='Blues', 
            xticklabels=[f"S{i+1}" for i in range(10)], 
            yticklabels=[f"S{i+1}" for i in range(10)])
plt.title("Cosine Similarity Matrix of Sentence Embeddings")
plt.show()

# 6. Find Top 2 Similar Sentences for New Query
query = ["The bowler took three wickets in one over"]
query_embedding = model.encode(query)
scores = cosine_similarity(query_embedding, embeddings)[0]

# Get indices of top 2 scores
top_indices = np.argsort(scores)[-2:][::-1]

print(f"Query: {query[0]}")
for idx in top_indices:
    print(f"Similarity: {scores[idx]:.4f} | Sentence: {sentences[idx]}")
